<?xml version="1.0" encoding="UTF-8"?>
<!--
  FSKit file-system module Info.plist (issue #10, spec §41).

  This declares the system extension as an FSKit module (`FSModuleType`) under
  the app-extension point `com.apple.fskit.fsmodule`. It is the on-device piece:
  the Swift `FSUnaryFileSystem` / `FSVolume` adapter (which calls into the
  Rust `FskitOps` logic) is built into this extension and signed with the
  matching entitlements (see git-lazy-mount.entitlements and README.md). It is
  intentionally NOT compiled by the cross-platform Rust build.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.git-lazy-mount.fskit.fsmodule</string>
    <key>CFBundleName</key>
    <string>git-lazy-mount FSKit module</string>
    <key>CFBundlePackageType</key>
    <string>XPC!</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>EXAppExtensionAttributes</key>
    <dict>
        <key>EXExtensionPointIdentifier</key>
        <string>com.apple.fskit.fsmodule</string>
    </dict>
    <key>FSModuleType</key>
    <string>FSUnaryFileSystem</string>
    <key>FSShortName</key>
    <string>glmfs</string>
    <key>FSSupportsBlockResources</key>
    <false/>
</dict>
</plist>
